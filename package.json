{
  "name": "deio-scroll-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:api": "pnpm --filter deio-scroll-api start",
    "dev:api:watch": "pnpm --filter deio-scroll-api start:watch",
    "dev:worker": "pnpm --filter deio-scroll-api worker",
    "dev:web": "pnpm --filter deio-scroll-web dev",
    "dev": "node scripts/dev.mjs",
    "typecheck": "pnpm --filter \"*\" typecheck"
  }
}
