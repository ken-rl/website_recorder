{
  "name": "websiterecorder-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:api": "pnpm --filter websiterecorder-api start",
    "dev:worker": "pnpm --filter websiterecorder-api worker",
    "dev:web": "pnpm --filter websiterecorder-web dev",
    "dev": "pnpm dev:api & pnpm dev:worker & pnpm dev:web",
    "typecheck": "pnpm --filter \"*\" typecheck"
  }
}
