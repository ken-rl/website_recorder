# Local HTTP control plane
HOST=127.0.0.1
PORT=3847
OUTPUT_DIR=./outputs

# Local API launches an embedded worker so captures work with one command.
# Set to 0 only when running `pnpm dev:worker` as a separate process.
EMBEDDED_WORKER=1

# Local development may capture localhost, but private LAN targets remain blocked.
# Hosted deployments must set ALLOW_LOCALHOST_TARGETS=0.
ALLOW_LOCALHOST_TARGETS=1
ALLOW_PRIVATE_TARGETS=0

# Worker safety limits
MAX_JOB_RUNTIME_MS=900000
MAX_OUTPUT_BYTES=1073741824

# Retention is opt-in locally. Uncomment when desired.
# SOURCE_RETENTION_DAYS=7
# OUTPUT_RETENTION_DAYS=30
