{
  "name": "deio-scroll",
  "version": "1.2.1",
  "description": "Deio Scroll API and worker for directed website scroll videos",
  "license": "MIT",
  "author": "ken-rl (https://github.com/ken-rl)",
  "repository": {
    "type": "git",
    "url": "https://github.com/ken-rl/website_recorder.git"
  },
  "bugs": {
    "url": "https://github.com/ken-rl/website_recorder/issues"
  },
  "homepage": "https://github.com/ken-rl/website_recorder#readme",
  "keywords": [
    "playwright",
    "screen-recording",
    "video",
    "webpage",
    "scroll",
    "mp4",
    "ffmpeg",
    "website-recorder"
  ],
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "bin": {
    "deio": "dist/cli.js"
  },
  "files": [
    "dist",
    "public",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "tsx src/api/server.ts",
    "start:watch": "tsx watch src/api/server.ts",
    "worker": "tsx src/worker.ts",
    "worker:watch": "tsx watch src/worker.ts",
    "record": "tsx src/cli.ts",
    "build:web": "pnpm --dir ../web build",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "pnpm run build:web && pnpm run clean && tsc -p tsconfig.build.json",
    "prepack": "pnpm run build",
    "test": "tsx --test \"src/**/*.test.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "better-sqlite3": "^12.11.1",
    "dotenv": "^16.4.7",
    "playwright": "^1.40.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
